<script>
  const params = new URLSearchParams(window.location.search);
  const room = params.get("room");

  if (room) {
    // Try to open your app via intent scheme (Android)
    window.location.href = `intent://invite?room=${room}#Intent;scheme=https;package=com.dano.number_lane;end`;
  } else {
    window.location.href = "https://play.google.com/store/apps/details?id=com.dano.number_lane";
  }
</script>
